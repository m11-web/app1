{
  "expo": {
    "name": "Rena Henna",
    "slug": "rena-henna-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "renahenna",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#E75480"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.renahenna.app"
    },
    "android": {
      "package": "com.renahenna.app",
      "newArchEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#E75480"
      },
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-router"
    ],
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1b66e1e3-8428-46e0-a670-a1b486bb1087"
      }
    }
  }
}
